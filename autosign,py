def get_login_form():
    log("请求登录弹窗页面获取 loginhash 和 formhash ...")
    url = f"{LOGIN_PAGE}&infloat=yes&inajax=1&ajaxtarget=fwin_content_login"
    try:
        r = session.get(url, timeout=10)
        r.raise_for_status()
        return r.text
    except Exception as e:
        log(f"获取登录表单失败: {e}")
        return None

def do_login(loginhash, formhash):
    log("开始提交登录请求 ...")
    login_url = f"{LOGIN_PAGE}&loginsubmit=yes&loginhash={loginhash}&inajax=1"
    payload = {
        "formhash": formhash,
        "referer": PORTAL,
        "username": USERNAME,
        "password": PASSWORD,
        "questionid": QUESTION_ID,
        "answer": ANSWER
    }
    try:
        r = session.post(login_url, data=payload, timeout=10)
        r.raise_for_status()
        # 检查登录是否成功
        if 'succeed' in r.text or 'window.location' in r.text:
            log("✓ 登录请求提交成功")
            return True
        else:
            log(f"✗ 登录可能失败，响应内容: {r.text[:200]}")
            return False
    except Exception as e:
        log(f"登录请求异常: {e}")
        return False

def get_sign_page():
    log("请求签到页面，准备获取新 formhash ...")
    try:
        r = session.get(SIGN_PAGE, timeout=10)
        r.raise_for_status()
        return r.text
    except Exception as e:
        log(f"获取签到页面失败: {e}")
        return None

def do_sign(formhash):
    log("准备发送签到请求 ...")
    sign_url = f"{BASE_URL}/plugin.php?id=k_misign:sign&operation=qiandao&formhash={formhash}&format=empty"
    log(f"签到请求地址：{sign_url}")
    try:
        r = session.get(sign_url, timeout=10)
        log("签到请求响应如下：")
        print(r.text)
        r.raise_for_status()
        parse_sign_response(r.text)
        return True
    except Exception as e:
        log(f"签到请求异常: {e}")
        return False

def parse_sign_response(response_text):
    """从签到响应内容中提取实际结果"""
    m = re.search(r'<!$CDATA\[(.*?)$\]>', response_text)
    if m:
        result = m.group(1)
        log(f"签到结果解析：{result}")
        return result
    else:
        log("签到结果解析失败，原始响应：")
        print(response_text)
        return None

def visit_profile():
    """访问个人主页"""
    log(f"开始访问个人主页: {PROFILE_URL}")
    try:
        r = session.get(PROFILE_URL, timeout=10)
        r.raise_for_status()
        
        # 检查访问结果
        if r.status_code == 200:
            # 检查页面内容，判断是否成功访问
            if "抱歉，您需要登录后才能查看" in r.text:
                log("✗ 访问个人主页失败：需要登录")
                return False
            elif "个人资料" in r.text or "空间" in r.text:
                log("✓ 成功访问个人主页")
                return True
            else:
                log("✓ 页面访问成功，但内容格式可能已变化")
                return True
        else:
            log(f"✗ 访问失败，状态码: {r.status_code}")
            return False
            
    except Exception as e:
        log(f"访问个人主页异常: {e}")
        return False

def perform_login_flow():
    """执行完整的登录流程"""
    global session
    session = requests.Session()
    session.headers.update({
        "User-Agent": USER_AGENT,
        "Host": "www.mydigit.cn",
        "Referer": PORTAL,
    })
    
    # 1. 访问首页获取初始 Cookie
    visit_homepage()
    time.sleep(1)
    
    # 2. 获取登录表单中的 hash
    login_html = get_login_form()
    if not login_html:
        return False
        
    loginhash = get_loginhash(login_html)
    formhash = get_formhash(login_html)
    
    if not loginhash or not formhash:
        log("未能提取 loginhash 或 formhash，登录中止")
        return False
        
    log(f"提取到 loginhash: {loginhash}, formhash: {formhash}")
    time.sleep(1)
    
    # 3. 提交登录
    if do_login(loginhash, formhash):
        # 保存会话以便下次使用
        save_session(session, USERNAME)
        return True
    else:
        return False

def main():
    global session
    
    log("===== Python 数码之家自动签到 开始 =====")
    
    success = False
    
    # 1. 尝试从缓存加载会话
    session = load_session(USERNAME)
    
    if session:
        # 2. 验证缓存会话是否有效
        if check_login_status(session):
            success = True
        else:
            log("缓存会话失效，尝试重新登录...")
            session = None # 重置全局 session
            
    if not success:
        # 3. 如果缓存无效或不存在，执行登录流程
        if perform_login_flow():
            log("重新登录成功，验证状态...")
            if check_login_status(session):
                success = True
            else:
                log("登录后状态验证失败")
        else:
            log("登录流程失败")

    # 4. 执行签到
    if success and session:
        log("开始执行签到...")
        sign_html = get_sign_page()
        if sign_html:
            current_formhash = get_formhash(sign_html)
            if current_formhash:
                log(f"获取到签到 formhash: {current_formhash}")
                time.sleep(2) # 礼貌延迟
                do_sign(current_formhash)
            else:
                log("未能从签到页面提取 formhash")
        else:
            log("无法获取签到页面")
        
        # ====== 新增：访问个人主页 ======
        log("开始执行个人主页访问...")
        time.sleep(1) # 礼貌延迟
        profile_success = visit_profile()
        
        if profile_success:
            log("✓ 个人主页访问完成")
        else:
            log("✗ 个人主页访问失败，可能需要重新登录")
    else:
        log("因登录失败，跳过签到和个人主页访问步骤")

    log("===== 程序结束 =====")

if __name__ == "__main__":
    main()
